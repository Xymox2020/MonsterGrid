<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg_gradient"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Glassmorphism Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:background="@drawable/glass_panel"
        android:elevation="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAYER 1 TURN"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-condensed-medium"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:textAllCaps="true"/>

        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:background="#4DFFFFFF"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p1Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P1: 20 HP"
                    android:textColor="#4FC3F7"
                    android:fontFamily="sans-serif-condensed"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p2Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P2: 20 HP"
                    android:textColor="#E57373"
                    android:fontFamily="sans-serif-condensed"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:id="@+id/dividerP3"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/p3Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/p3Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P3: 20 HP"
                    android:textColor="#81C784"
                    android:fontFamily="sans-serif-condensed"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:id="@+id/dividerP4"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/p4Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/p4Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P4: 20 HP"
                    android:textColor="#FFF176"
                    android:fontFamily="sans-serif-condensed"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/expBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:max="6"
            android:progress="0"
            android:progressDrawable="@drawable/custom_progress_bar"/>
    </LinearLayout>

    <!-- Game Grid Container -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/controls"
        android:clipChildren="false"
        android:clipToPadding="false">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false">

                <GridLayout
                    android:id="@+id/gameGrid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:columnCount="10"
                    android:rowCount="10"
                    android:clipChildren="false"
                    android:clipToPadding="false">
                    <!-- Cells will be added programmatically -->
                </GridLayout>
            </ScrollView>
        </HorizontalScrollView>
    </FrameLayout>

    <!-- Visual Layer for Effects - Low elevation to stay below overlays -->
    <FrameLayout
        android:id="@+id/effectLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="2dp"
        android:clickable="false"
        android:focusable="false"/>

    <!-- Glassmorphism Controls -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_margin="12dp"
        android:background="@drawable/glass_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnAction1"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="MOVE"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_move_bg"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-condensed-medium"/>

            <Button
                android:id="@+id/btnAction2"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="ATTACK"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_attack_bg"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-condensed-medium"/>

            <Button
                android:id="@+id/btnEndTurn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:text="END"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_skip_bg"
                android:fontFamily="sans-serif-condensed-medium"/>
        </LinearLayout>

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="SYSTEMS ONLINE"
            android:textColor="#B0B0B0"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:letterSpacing="0.05"/>
    </LinearLayout>

    <!-- Player Selection Overlay -->
    <FrameLayout
        android:id="@+id/selectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60A0B10"
        android:visibility="visible"
        android:elevation="150dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SELECT PLAYERS"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="sans-serif-condensed-medium"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <Button android:id="@+id/btn2Players" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:text="2 PLAYERS" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" app:strokeColor="#4DFFFFFF" android:fontFamily="sans-serif-condensed"/>
            <Button android:id="@+id/btn3Players" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:text="3 PLAYERS" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" app:strokeColor="#4DFFFFFF" android:fontFamily="sans-serif-condensed"/>
            <Button android:id="@+id/btn4Players" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:text="4 PLAYERS" android:textColor="#FFFFFF" app:strokeColor="#4DFFFFFF" android:fontFamily="sans-serif-condensed"/>
        </LinearLayout>
    </FrameLayout>

    <!-- WOW Upgrade Overlay -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DD000000"
        android:visibility="gone"
        android:elevation="500dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:background="@drawable/glass_panel"
            android:backgroundTint="#0D47A1">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⭐ LEVEL UP ⭐"
                android:textColor="#FFD700"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CHOOSE YOUR ASCENSION"
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:fontFamily="sans-serif-condensed-light"
                android:letterSpacing="0.2"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <Button android:id="@+id/upgrade1" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:layout_marginBottom="16dp" android:background="@drawable/upgrade_button_bg" android:fontFamily="sans-serif-condensed-medium" android:textSize="18sp" android:elevation="4dp"/>
            <Button android:id="@+id/upgrade2" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:layout_marginBottom="16dp" android:background="@drawable/upgrade_button_bg" android:fontFamily="sans-serif-condensed-medium" android:textSize="18sp" android:elevation="4dp"/>
            <Button android:id="@+id/upgrade3" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:background="@drawable/upgrade_button_bg" android:fontFamily="sans-serif-condensed-medium" android:textSize="18sp" android:elevation="4dp"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Simple Game Over Overlay -->
    <FrameLayout
        android:id="@+id/gameOverOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:elevation="1000dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/winnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYER 1 VICTORIOUS"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to play again"
                android:textColor="#B0FFFFFF"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:gravity="center"/>
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>