<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F">

    <!-- Premium Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:elevation="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAYER 1 TURN"
            android:textColor="#FFD700"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:textAllCaps="true"/>

        <View
            android:layout_width="60dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:background="#FFD700"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p1Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P1: 20 HP"
                    android:textColor="#00E5FF"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/p1Level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LVL 1"
                    android:textColor="#00B8D4"
                    android:textSize="12sp"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#333333"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p2Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P2: 20 HP"
                    android:textColor="#FF1744"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/p2Level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LVL 1"
                    android:textColor="#D50000"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/expBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:max="6"
            android:progress="0"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="#00FF00"/>
    </LinearLayout>

    <!-- Professional Game Grid Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/controls"
        android:padding="4dp">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scrollbars="none">
            
            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                
                <GridLayout
                    android:id="@+id/gameGrid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:columnCount="10"
                    android:rowCount="10"
                    android:background="#222222"
                    android:padding="1dp">
                    <!-- Cells -->
                </GridLayout>
            </ScrollView>
        </HorizontalScrollView>
    </FrameLayout>

    <!-- Modern Controls Footer -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnAction1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="MOVE"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium"
                android:elevation="4dp"/>

            <Button
                android:id="@+id/btnAction2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="ATTACK"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C62828"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium"
                android:elevation="4dp"/>

            <Button
                android:id="@+id/btnEndTurn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:text="SKIP"
                android:textColor="#FFFFFF"
                android:backgroundTint="#455A64"
                android:fontFamily="sans-serif-medium"
                android:elevation="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="READY FOR ENGAGEMENT"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="italic"
            android:gravity="center"
            android:letterSpacing="0.05"/>
    </LinearLayout>

    <!-- Cinematic Upgrade Overlay -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2000000"
        android:visibility="gone"
        android:elevation="20dp"
        android:clickable="true"
        android:focusable="true">
        
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="#121212">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NEW ABILITY UNLOCKED"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>
                
            <Button android:id="@+id/upgrade1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:strokeColor="#333333"/>
            <Button android:id="@+id/upgrade2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:layout_marginBottom="12dp" android:strokeColor="#333333"/>
            <Button android:id="@+id/upgrade3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="64dp" android:textColor="#FFFFFF" android:strokeColor="#333333"/>
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>
