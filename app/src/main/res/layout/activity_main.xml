<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0C08"
    android:fitsSystemWindows="true"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Fantasy Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_margin="8dp"
        android:background="@drawable/fantasy_panel"
        android:elevation="8dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PLAYER 1 TURN"
            android:textColor="#FFD700"
            android:textSize="@dimen/text_size_status"
            android:fontFamily="serif"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:textAllCaps="true"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"/>

        <View
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:background="#8B6B4C"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p1Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P1: 20 HP"
                    android:textColor="#E0E0E0"
                    android:fontFamily="serif"
                    android:textSize="@dimen/text_size_stats"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:background="#4D8B6B4C"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/p2Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P2: 20 HP"
                    android:textColor="#E0E0E0"
                    android:fontFamily="serif"
                    android:textSize="@dimen/text_size_stats"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:id="@+id/dividerP3"
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:background="#4D8B6B4C"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/p3Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/p3Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P3: 20 HP"
                    android:textColor="#E0E0E0"
                    android:fontFamily="serif"
                    android:textSize="@dimen/text_size_stats"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:id="@+id/dividerP4"
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:background="#4D8B6B4C"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/p4Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:id="@+id/p4Stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P4: 20 HP"
                    android:textColor="#E0E0E0"
                    android:fontFamily="serif"
                    android:textSize="@dimen/text_size_stats"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/expBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="6"
            android:progress="0"
            android:progressDrawable="@drawable/custom_progress_bar"/>
    </LinearLayout>

    <!-- Game Grid Container -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/controls"
        android:clipChildren="false"
        android:clipToPadding="false">

        <HorizontalScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:scrollbars="none"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false">

                <GridLayout
                    android:id="@+id/gameGrid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:columnCount="10"
                    android:rowCount="10"
                    android:clipChildren="false"
                    android:clipToPadding="false">
                </GridLayout>
            </ScrollView>
        </HorizontalScrollView>
    </FrameLayout>

    <!-- Visual Layer for Effects -->
    <FrameLayout
        android:id="@+id/effectLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="2dp"
        android:clickable="false"
        android:focusable="false"/>

    <!-- Fantasy Controls -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_margin="8dp"
        android:background="@drawable/fantasy_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="60dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnAction1"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:layout_weight="1"
                android:text="MOVE"
                android:textColor="#FFFFFF"
                android:background="@drawable/fantasy_button_move"
                android:layout_marginEnd="6dp"
                android:textSize="@dimen/text_size_button"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>

            <Button
                android:id="@+id/btnAction2"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:layout_weight="1"
                android:text="ATTACK"
                android:textColor="#FFFFFF"
                android:background="@drawable/fantasy_button_attack"
                android:layout_marginEnd="6dp"
                android:textSize="@dimen/text_size_button"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>

            <Button
                android:id="@+id/btnEndTurn"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:layout_weight="0.8"
                android:text="END"
                android:textColor="#FFFFFF"
                android:background="@drawable/fantasy_button_gold"
                android:textSize="@dimen/text_size_button"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"/>
        </LinearLayout>

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Waiting for your command..."
            android:textColor="#BDB76B"
            android:textSize="@dimen/text_size_log"
            android:fontFamily="serif"
            android:textStyle="italic"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Player Selection Overlay -->
    <FrameLayout
        android:id="@+id/selectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FA000000"
        android:visibility="visible"
        android:elevation="150dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:minWidth="320dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="@drawable/fantasy_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SELECT WARRIORS"
                android:textColor="#FFD700"
                android:textSize="@dimen/text_size_title"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:gravity="center"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2"
                android:layout_marginBottom="32dp"/>

            <Button android:id="@+id/btn2Players" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="60dp" android:text="2 WARRIORS" android:textColor="#FFFFFF" android:background="@drawable/fantasy_button_gold" android:layout_marginBottom="16dp" android:fontFamily="serif" android:textStyle="bold" android:textSize="@dimen/text_size_button" android:shadowColor="#000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="1"/>
            <Button android:id="@+id/btn3Players" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="60dp" android:text="3 WARRIORS" android:textColor="#FFFFFF" android:background="@drawable/fantasy_button_gold" android:layout_marginBottom="16dp" android:fontFamily="serif" android:textStyle="bold" android:textSize="@dimen/text_size_button" android:shadowColor="#000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="1"/>
            <Button android:id="@+id/btn4Players" style="@style/Widget.AppCompat.Button.Borderless" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="60dp" android:text="4 WARRIORS" android:textColor="#FFFFFF" android:background="@drawable/fantasy_button_gold" android:fontFamily="serif" android:textStyle="bold" android:textSize="@dimen/text_size_button" android:shadowColor="#000000" android:shadowDx="1" android:shadowDy="1" android:shadowRadius="1"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Upgrade Overlay -->
    <FrameLayout
        android:id="@+id/upgradeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2000000"
        android:visibility="gone"
        android:elevation="500dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/particleContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="0dp"
            android:clipChildren="false">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LEVEL UP"
                android:textColor="#FFD700"
                android:textSize="@dimen/text_size_medium"
                android:fontFamily="sans-serif-condensed-light"
                android:letterSpacing="0.3"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose your upgrade"
                android:textColor="#B0BEC5"
                android:textSize="@dimen/text_size_small"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="0dp">

                <com.example.monstergrid.ShimmerImageView
                    android:id="@+id/upgrade1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <com.example.monstergrid.ShimmerImageView
                    android:id="@+id/upgrade2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <com.example.monstergrid.ShimmerImageView
                    android:id="@+id/upgrade3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="1dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Game Over Overlay -->
    <FrameLayout
        android:id="@+id/gameOverOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:elevation="1000dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/fantasy_panel"
            android:padding="32dp">

            <TextView
                android:id="@+id/winnerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VICTORIOUS"
                android:textColor="#FFD700"
                android:textSize="@dimen/text_size_large"
                android:fontFamily="serif"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to play again"
                android:textColor="#F5DEB3"
                android:textSize="@dimen/text_size_small"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:layout_marginTop="24dp"
                android:gravity="center"/>
        </LinearLayout>
    </FrameLayout>

</RelativeLayout>